# Frontend environment — copy to .env and fill in values
# ──────────────────────────────────────────────────────────────

# API base URL for direct requests (leave blank to use the Vite dev proxy instead)
VITE_API_BASE_URL=

# Target URL for the Vite proxy (Node.js env var, NOT exposed to browser)
# When running with Docker Compose this should be http://backend:8000
BACKEND_URL=http://localhost:8000
