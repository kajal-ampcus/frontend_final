DJANGO_ENV=dev

SECRET_KEY=django-insecure-change-this

DB_NAME=db_name
DB_USER=db_user
DB_PASSWORD=db_password
DB_HOST=127.0.0.1
DB_PORT=5432

ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=https://yourfrontend.com,https://admin.yourapp.com

JWT_SECRET_KEY=supersecretjwt

# Employee credential email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
EMPLOYEE_LOGIN_URL=http://localhost:5173/login
ADMIN_EMAIL=admin1@example.com,admin2@example.com
REPORT_EMAIL=report1@example.com,report2@example.com